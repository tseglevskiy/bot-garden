# OpenClaw Bootstrap — Environment Variables
# Copy this file to .env and fill in the values you need.
#
#   cp .env.example .env
#   ./bootstrap.sh

# ---------------------------------------------------------------------------
# AI Provider (pick ONE — the first non-empty key wins)
# ---------------------------------------------------------------------------

# OpenRouter — access 200+ models via a single key
# Get key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Anthropic — Claude models directly
# Get key: https://console.anthropic.com/settings/api-keys
#ANTHROPIC_API_KEY=

# OpenAI — GPT / o-series models
# Get key: https://platform.openai.com/api-keys
#OPENAI_API_KEY=

# Google Gemini
# Get key: https://aistudio.google.com/apikey
#GEMINI_API_KEY=

# Mistral AI
# Get key: https://console.mistral.ai/api-keys
#MISTRAL_API_KEY=

# xAI (Grok)
# Get key: https://console.x.ai/
#XAI_API_KEY=

# ---------------------------------------------------------------------------
# Slack (Socket Mode — recommended for Docker)
# ---------------------------------------------------------------------------
# Full setup guide: https://docs.openclaw.ai/channels/slack
#
# Step 1: Create a Slack app at https://api.slack.com/apps
# Step 2: Enable Socket Mode (Settings > Socket Mode)
# Step 3: Create an App-Level Token with scope "connections:write"
#         (Settings > Basic Information > App-Level Tokens)
#         — this gives you the xapp-... token
# Step 4: Install the app to your workspace
#         (Settings > Install App)
#         — this gives you the xoxb-... Bot Token

# Bot Token — starts with xoxb-
SLACK_BOT_TOKEN=

# App-Level Token (Socket Mode) — starts with xapp-
SLACK_APP_TOKEN=

# ---------------------------------------------------------------------------
# Telegram (Bot API — long polling, no webhook needed)
# ---------------------------------------------------------------------------
# Chat with @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Deployment profile: "slack" or "telegram"
# ---------------------------------------------------------------------------
#   slack    — Slack channels, no GPU, no Whisper (default)
#   telegram — Telegram channels, GPU + Whisper sidecar for voice messages
DEPLOY_PROFILE=slack

# ---------------------------------------------------------------------------
# Gateway settings (optional — defaults shown)
# ---------------------------------------------------------------------------

# Build from source to install extra packages (recommended).
# Set to ghcr.io/openclaw/openclaw:latest to skip the build and use pre-built.
OPENCLAW_IMAGE=openclaw:local

# Extra apt packages baked into the image at build time.
# Only used when OPENCLAW_IMAGE=openclaw:local.
OPENCLAW_DOCKER_APT_PACKAGES="python3 python3-pip jq make unzip ripgrep"

# Gateway port (default 18789)
#OPENCLAW_GATEWAY_PORT=18789

# Gateway bind: "lan" exposes on local network, "loopback" = localhost only
#OPENCLAW_GATEWAY_BIND=lan

# Auth token for the web UI. Auto-generated if left empty.
# Use: openssl rand -hex 32
#OPENCLAW_GATEWAY_TOKEN=

# Directory where OpenClaw stores config and agent data (on the host)
#OPENCLAW_CONFIG_DIR=~/.openclaw

# Workspace directory mounted into containers
#OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
